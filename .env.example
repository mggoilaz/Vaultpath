# .env.example — vaultpath
# Copy to .env and fill in your values — NEVER commit .env to git

# Tailscale IP of your server (find at login.tailscale.com → Machines)
SERVER_TS_IP=YOUR_TAILSCALE_IP

# Local network IP of your server (optional — auto-detected)
SERVER_LAN_IP=YOUR_LAN_IP

# Your SSH username on the server
SERVER_USER=YOUR_USERNAME

# SSH key path (generated by setup.sh)
SSH_KEY=~/.ssh/vaultpath_id_ed25519

# Tailscale auth key (login.tailscale.com → Settings → Auth keys — revoke after use)
TAILSCALE_AUTH_KEY=YOUR_AUTH_KEY
